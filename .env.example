# Copy this file to .env and fill in your credentials.
# .env is git-ignored and must never be committed.

# ── AWS Bedrock (11 models) ────────────────────────────────────────────────────
# Claude Opus 4.6, Sonnet 4.6, Haiku 4.5, Gemma 3 27B, GLM-5, MiniMax M2.5,
# Command R+, Nova 2 Pro, Jamba 1.5 Large, Nemotron 3 Super, Gemma 3 27B
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure AI Foundry (7 models) ────────────────────────────────────────────────
# GPT-OSS 120B, DeepSeek V3.2, DeepSeek R1, Kimi K2.5, Mistral Large 3,
# Llama 4 Maverick, Phi 4
# Shared API key; per-model endpoints go in model_registry.json (azure_api_base).
AZURE_API_KEY=
AZURE_API_VERSION=2024-05-01-preview
AZURE_API_BASE=https://psycho-llm-resource.services.ai.azure.com/models

# ── OpenAI API (3 models) ─────────────────────────────────────────────────────
# GPT-5.4, GPT-5.4 Mini, GPT-5.4 Nano
OPENAI_API_KEY=

# ── Google AI (2 models) ──────────────────────────────────────────────────────
# Gemini 3.1 Pro, Gemini 3.1 Flash
GEMINI_API_KEY=

# ── xAI (1 model) ─────────────────────────────────────────────────────────────
# Grok 4.20 Beta
XAI_API_KEY=

# ── Alibaba Cloud DashScope (1 model) ─────────────────────────────────────────
# Qwen 3.5
DASHSCOPE_API_KEY=

# ── Xiaomi MiMo (1 model) ─────────────────────────────────────────────────────
# MiMo-V2-Pro — direct free tier, OpenAI-compatible endpoint
MIMO_API_KEY=
MIMO_BASE_URL=

# ── Prolific survey server ─────────────────────────────────────────────────────
PROLIFIC_API_TOKEN=
PROLIFIC_FLASK_SECRET=
PROLIFIC_COMPLETION_CODE=   # fixed code from Prolific study settings (URL-redirect completion)
